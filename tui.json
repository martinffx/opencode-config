{
  "$schema": "https://opencode.ai/tui.json",
  "theme": "catppuccin",
  "keybinds": {
    "command_list": "<leader>p",
    "history_previous": "up,ctrl+p",
    "history_next": "down,ctrl+n",
    "messages_half_page_up": "ctrl+u,ctrl+alt+u",
    "messages_page_up": "pageup,alt+v",
    "messages_page_down": "pagedown,ctrl+v",
    "input_clear": "ctrl+c,ctrl+g"
  }
}